#!/bin/sh
# Pre-commit hook for habit-tracker.
# Runs secret scanning and the full test suite before allowing a commit.
# Both checks must pass — failure in either blocks the commit entirely.

set -e

echo "🔍 Scanning for secrets..."

# Patterns that indicate private credentials or tokens.
# Checks all staged files (text only) for any of these markers.
SECRET_PATTERNS="ghp_[a-zA-Z0-9]+|sk-[a-zA-Z0-9]+|Bearer [a-zA-Z0-9]+|-----BEGIN (RSA|EC|OPENSSH) PRIVATE KEY|password\s*=\s*['\"][^'\"]+['\"]|api[_-]?key\s*=\s*['\"][^'\"]+['\"]"

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -v "node_modules" | grep -v ".husky" || true)

if [ -n "$STAGED_FILES" ]; then
  MATCHES=$(echo "$STAGED_FILES" | xargs grep -Pl "$SECRET_PATTERNS" 2>/dev/null || true)
  if [ -n "$MATCHES" ]; then
    echo "❌ Possible secret detected in:"
    echo "$MATCHES"
    echo "Remove the secret and try again."
    exit 1
  fi
fi

echo "✅ No secrets found."
echo ""
echo "🧪 Running tests..."

npm test

echo "✅ All tests passed."
